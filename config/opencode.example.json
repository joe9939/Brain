    "self-optimizer": {"mode":"subagent","model":"zen/deepseek-v4-flash-free","description":"Ch9 prompt evolution every 3 tasks","permission":{"read":"allow"}},
    "offline-consolidation": {"mode":"subagent","model":"zen/deepseek-v4-flash-free","description":"Ch3.2.1+Ch11.2 sleep consolidation","permission":{"read":"allow"}}
