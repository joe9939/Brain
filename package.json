{
  "name": "brain-agent",
  "version": "1.0.0",
  "description": "Brain-inspired Foundation Agent for OpenCode — arXiv 2504.01990 · 20 brain region agents · 98% paper alignment",
  "main": "install.js",
  "bin": {
    "brain-agent": "install.js"
  },
  "scripts": {
    "test": "node tests/runner.js --all",
    "test:bun": "bun test tests/unit/ tests/circuits/ tests/integration/ tests/e2e/ tests/qc/",
    "test:all": "bun test tests/ && node tests/runner.js --all",
    "test:e2e": "node tests/brain-e2e-runner.js",
    "test:behavioral": "npx agentest run --config agentest.config.ts",
    "typecheck": "tsc --noEmit --project tests/tsconfig.json",
    "publish:patch": "node install.js --publish patch",
    "publish:minor": "node install.js --publish minor",
    "publish:major": "node install.js --publish major"
  },
  "keywords": [
    "opencode",
    "agent",
    "brain",
    "neuroscience",
    "foundation-agent",
    "multi-agent",
    "arxiv"
  ],
  "license": "MIT",
  "repository": "github:joe9939/brain-agent",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "mineflayer": "^4.37.1"
  },
  "devDependencies": {
    "@agentesting/agentest": "^0.0.22",
    "@opencode-ai/sdk": "^1.17.11",
    "gif-encoder": "^0.7.2",
    "pngjs": "^7.0.0"
  }
}
